{
  "name": "aws-handson-kb-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "esbuild lambda/src/handler.ts --bundle --platform=node --target=node22 --outdir=lambda/dist --sourcemap",
    "zip": "npm run build && bestzip lambda/kb-api.zip lambda/dist/*",
    "upload": "ts-node -P tsconfig.scripts.json scripts/upload.ts",
    "deploy": "ts-node -P tsconfig.scripts.json scripts/deploy.ts",
    "sync": "ts-node -P tsconfig.scripts.json scripts/sync.ts",
    "test": "ts-node -P tsconfig.scripts.json scripts/test.ts",
    "update": "ts-node -P tsconfig.scripts.json scripts/update.ts",
    "delete": "ts-node -P tsconfig.scripts.json scripts/delete.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.848.0",
    "@aws-sdk/client-s3": "^3.850.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^24.1.0",
    "@types/readline-sync": "^1.4.8",
    "bestzip": "^2.2.1",
    "esbuild": "^0.25.8",
    "fs": "^0.0.1-security",
    "inquirer": "^12.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
